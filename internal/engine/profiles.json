  "test_fixtures": [
    {
      "name": "Magento 2.1.18 legacy mapping",
      "framework": "magento2",
      "version": "2.1.18",
      "source_prefix": "version-specific:magento2@2.1.18",
      "expected": {
        "php_version": "7.1",
        "db_version": "10.0",
        "cache": "redis",
        "cache_version": "5.0",
        "search": "elasticsearch",
        "search_version": "2.4",
        "queue_version": "3.7"
      }
    },
    {
      "name": "Magento 2.3.7 legacy mapping",
      "framework": "magento2",
      "version": "2.3.7",
      "source_prefix": "version-specific:magento2@2.3.7",
      "expected": {
        "php_version": "7.4",
        "db_version": "10.4",
        "cache": "redis",
        "cache_version": "5.0",
        "search": "elasticsearch",
        "search_version": "7.9",
        "queue_version": "3.8"
      }
    },
    {
      "name": "Magento 2.4.6-p13 maps to PHP 8.2 and MariaDB 10.11",
      "framework": "magento2",
      "version": "2.4.6-p13",
      "source_prefix": "version-specific:magento2@2.4.6",
      "expected": {
        "php_version": "8.2",
        "db_version": "10.11",
        "search_version": "2.19",
        "queue_version": "3.13"
      }
    },
    {
      "name": "Magento 2 uses search and cache profile",
      "framework": "magento2",
      "version": "2.4.7",
      "source_prefix": "version-specific:magento2@2.4.7",
      "expected": {
        "php_version": "8.3",
        "db_version": "10.6",
        "cache": "redis",
        "search": "opensearch",
        "search_version": "2.12",
        "queue": "rabbitmq"
      }
    },
    {
      "name": "Magento version constraints are parsed",
      "framework": "magento2",
      "version": "^2.4.7-p3",
      "source_prefix": "version-specific:magento2@2.4.7",
      "expected": {
        "php_version": "8.3",
        "db_version": "10.6",
        "cache": "redis",
        "search_version": "2.12",
        "queue_version": "3.12"
      }
    },
    {
      "name": "Magento 2.4.8-p3 prefers PHP 8.4 and OpenSearch 3",
      "framework": "magento2",
      "version": "2.4.8-p3",
      "source_prefix": "version-specific:magento2@2.4.8",
      "expected": {
        "php_version": "8.4",
        "db_version": "11.4",
        "search_version": "3.0",
        "queue_version": "3.13"
      }
    },
    {
      "name": "Drupal 11 uses PHP 8.4",
      "framework": "drupal",
      "version": "11.0",
      "source_prefix": "version-specific:drupal@11",
      "expected": {
        "php_version": "8.4"
      }
    },
    {
      "name": "Laravel 11 uses version profile",
      "framework": "laravel",
      "version": "^11.0",
      "source_prefix": "version-specific:laravel@11",
      "expected": {
        "php_version": "8.3",
        "db": "mariadb",
        "web_server": "nginx",
        "cache": "none",
        "search": "none",
        "cache_version": "",
        "search_version": ""
      }
    },
    {
      "name": "Laravel unknown major falls back",
      "framework": "laravel",
      "version": "99.0",
      "source": "framework-defaults",
      "warning_contains": "No version-specific profile for laravel major 99",
      "expected": {
        "php_version": "8.4",
        "db": "mariadb"
      }
    },
    {
      "name": "Laravel unparsable version falls back",
      "framework": "laravel",
      "version": "dev-main",
      "source": "framework-defaults",
      "warning_contains": "Could not parse major version",
      "expected": {
        "php_version": "8.4"
      }
    },
    {
      "name": "Next.js has no database",
      "framework": "nextjs",
      "version": "14",
      "source": "framework-defaults",
      "expected": {
        "db": "none",
        "db_version": "",
        "cache": "none",
        "search": "none"
      }
    },
    {
      "name": "Emdash uses node-first local defaults",
      "framework": "emdash",
      "version": "^0.1.0",
      "source": "framework-defaults",
      "expected": {
        "node_version": "22",
        "db": "none",
        "web_server": "none",
        "cache": "none",
        "search": "none",
        "queue": "none"
      }
    },
    {
      "name": "Symfony 5.2 uses legacy mapping",
      "framework": "symfony",
      "version": "5.2",
      "source_prefix": "version-specific:symfony@5",
      "expected": {
        "php_version": "7.4",
        "db_version": "10.4",
        "cache": "none",
        "search": "none",
        "cache_version": "",
        "search_version": ""
      }
    },
    {
      "name": "Symfony 7 uses PHP 8.3",
      "framework": "symfony",
      "version": "7.2",
      "source_prefix": "version-specific:symfony@7.2",
      "expected": {
        "php_version": "8.3"
      }
    },
    {
      "name": "Unsupported framework returns error",
      "framework": "rails",
      "version": "7",
      "expect_error": true
    },
    {
      "name": "WordPress 5.7 legacy mapping",
      "framework": "wordpress",
      "version": "5.7",
      "source_prefix": "version-specific:wordpress@5.0",
      "expected": {
        "php_version": "7.4",
        "db_version": "10.4"
      }
    },
    {
      "name": "WordPress 6.7 modern mapping",
      "framework": "wordpress",
      "version": "6.7",
      "source_prefix": "version-specific:wordpress@6.6",
      "expected": {
        "php_version": "8.3",
        "db_version": "10.11"
      }
    },
    {
      "name": "Drupal 7 modern uses PHP 7.4",
      "framework": "drupal",
      "version": "7.94",
      "source_prefix": "version-specific:drupal@7.94",
      "expected": {
        "php_version": "7.4",
        "db_version": "10.4"
      }
    },
    {
      "name": "Laravel 4 uses PHP 5.6",
      "framework": "laravel",
      "version": "4.2",
      "source_prefix": "version-specific:laravel@4",
      "expected": {
        "php_version": "5.6",
        "db_version": "10.1"
      }
    }
